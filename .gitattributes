# Force LF regardless of core.autocrlf: Windows checkouts with autocrlf=true
# otherwise convert *.sh to CRLF, which trips shellcheck's line-continuation
# parser (spurious SC2215 on backslash-continued commands) without the
# committed blob actually having a bug.
*.sh text eol=lf
*.tmpl text eol=lf
# gofmt treats CRLF as unformatted; CI runs gofmt -l on a Linux checkout,
# so a CRLF-smudged local checkout diverges from what CI validates.
*.go text eol=lf
# Extensionless rc files: shell content that must stay LF for the same reason.
dot_bashrc text eol=lf
dot_zshrc text eol=lf
# chezmoi applies from the working tree, so an autocrlf-smudged checkout
# would push CRLF into the live ~/.claude files.
home/private_dot_claude/*.md text eol=lf
