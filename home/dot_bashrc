# shellcheck disable=SC1090,SC1091  # rc file: all sourced paths are runtime-dynamic by design
# Not running interactively? Stop here.
case $- in
    *i*) ;;
    *) return ;;
esac

# Shared config; local.sh is unmanaged machine-local config and stays last
# so its definitions override the managed files.
for f in "$HOME/.config/shell/exports.sh" "$HOME/.config/shell/aliases.sh" "$HOME/.config/shell/functions.sh" "$HOME/.config/shell/local.sh"; do
    [ -r "$f" ] && source "$f"
done

# History
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoredups:ignorespace
shopt -s histappend
shopt -s checkwinsize

# Prompt
PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

# Windows Terminal reads cwd from OSC 9;9 so duplicate tab/pane opens here;
# cygpath guard keeps this a no-op outside Git Bash (Linux, WSL).
if [ -n "$WT_SESSION" ] && command -v cygpath >/dev/null 2>&1; then
    PROMPT_COMMAND=${PROMPT_COMMAND:+"$PROMPT_COMMAND; "}'printf "\e]9;9;%s\e\\" "$(cygpath -w "$PWD")"'
fi

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ]          && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# pyenv
if command -v pyenv &>/dev/null; then eval "$(pyenv init -)"; fi

# sdkman (must stay near bottom)
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]] && source "$SDKMAN_DIR/bin/sdkman-init.sh"

# cargo
[ -s "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
